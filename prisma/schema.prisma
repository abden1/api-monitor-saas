generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum MonitorType {
  HTTP
  PING
  PORT
  DNS
  SSL
  KEYWORD
}

enum MonitorStatus {
  UP
  DOWN
  DEGRADED
  PAUSED
  PENDING
}

enum CheckStatus {
  UP
  DOWN
  DEGRADED
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum AlertChannelType {
  EMAIL
  SMS
  SLACK
  DISCORD
  PAGERDUTY
  OPSGENIE
  WEBHOOK
}

enum AlertTrigger {
  DOWN
  RECOVERY
  DEGRADED
  SSL_EXPIRY_7
  SSL_EXPIRY_14
  SSL_EXPIRY_30
  RESPONSE_TIME
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum StatusPageTemplate {
  LIGHT
  DARK
  MINIMAL
  DETAILED
}

enum ComponentStatus {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
  MAINTENANCE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── Auth (NextAuth compatible) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  teamMembers   TeamMember[]
  incidentUpdates IncidentUpdate[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Teams ──────────────────────────────────────────────────────────────────

model Team {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  plan             Plan     @default(FREE)
  stripeCustomerId String?  @unique
  stripeSubId      String?  @unique
  planExpiresAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members          TeamMember[]
  monitors         Monitor[]
  statusPages      StatusPage[]
  alertChannels    AlertChannel[]
  incidents        Incident[]
  maintenanceWindows MaintenanceWindow[]
  apiKeys          ApiKey[]
  subscription     Subscription?
  invitations      Invitation[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Invitation {
  id        String           @id @default(cuid())
  teamId    String
  email     String
  role      UserRole         @default(MEMBER)
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

// ─── Monitors ───────────────────────────────────────────────────────────────

model Monitor {
  id              String        @id @default(cuid())
  teamId          String
  name            String
  url             String
  type            MonitorType   @default(HTTP)
  method          String        @default("GET")
  headers         String?       @db.Text  // encrypted JSON
  body            String?       @db.Text  // encrypted
  expectedStatus  Int           @default(200)
  expectedContent String?
  contentType     String?       @default("keyword") // keyword | regex | jsonpath
  timeout         Int           @default(30000)     // ms
  interval        Int           @default(60)        // seconds
  regions         String[]      @default(["us-east"])
  isActive        Boolean       @default(true)
  status          MonitorStatus @default(PENDING)
  lastCheckedAt   DateTime?
  lastStatusChange DateTime?
  sslExpiresAt    DateTime?
  sslExpiryAlertDays Int[]     @default([7, 14, 30])
  responseTimeThreshold Int    @default(5000)       // ms
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  team            Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  checkResults    CheckResult[]
  incidents       Incident[]
  alertRules      AlertRule[]
  statusPageComponents StatusPageComponent[]
  sslHistory      SslHistory[]
  uptimeDaily     UptimeDaily[]

  @@map("monitors")
}

// ─── Check Results (TimescaleDB hypertable) ──────────────────────────────────

model CheckResult {
  id           String      @id @default(cuid())
  timestamp    DateTime    @default(now())
  monitorId    String
  region       String      @default("us-east")
  status       CheckStatus
  responseTime Int?        // ms
  statusCode   Int?
  errorMessage String?
  sslExpiresAt DateTime?
  checkedAt    DateTime    @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, timestamp(sort: Desc)])
  @@index([timestamp])
  @@map("check_results")
}

// ─── Uptime Aggregation ──────────────────────────────────────────────────────

model UptimeDaily {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  monitorId       String
  uptimePercent   Float    @default(100)
  avgResponseTime Int?
  checkCount      Int      @default(0)
  failCount       Int      @default(0)
  degradedCount   Int      @default(0)

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@unique([monitorId, date])
  @@index([monitorId, date(sort: Desc)])
  @@map("uptime_daily")
}

// ─── SSL History ─────────────────────────────────────────────────────────────

model SslHistory {
  id          String   @id @default(cuid())
  monitorId   String
  issuer      String?
  subject     String?
  validFrom   DateTime?
  validTo     DateTime?
  isValid     Boolean  @default(true)
  isSelfSigned Boolean @default(false)
  daysUntilExpiry Int?
  recordedAt  DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@map("ssl_history")
}

// ─── Incidents ───────────────────────────────────────────────────────────────

model Incident {
  id               String         @id @default(cuid())
  teamId           String
  monitorId        String?
  title            String
  description      String?        @db.Text
  status           IncidentStatus @default(INVESTIGATING)
  autoCreated      Boolean        @default(false)
  resolvedAt       DateTime?
  postMortem       String?        @db.Text
  affectedComponents String[]     @default([])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  team    Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  monitor Monitor?        @relation(fields: [monitorId], references: [id], onDelete: SetNull)
  updates IncidentUpdate[]

  @@map("incidents")
}

model IncidentUpdate {
  id         String         @id @default(cuid())
  incidentId String
  message    String         @db.Text
  status     IncidentStatus
  createdById String?
  createdAt  DateTime       @default(now())

  incident  Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("incident_updates")
}

// ─── Status Pages ────────────────────────────────────────────────────────────

model StatusPage {
  id           String             @id @default(cuid())
  teamId       String
  title        String
  description  String?
  slug         String             @unique
  customDomain String?            @unique
  logoUrl      String?
  faviconUrl   String?
  brandColor   String             @default("#6366f1")
  template     StatusPageTemplate @default(LIGHT)
  isPublished  Boolean            @default(false)
  showUptime   Boolean            @default(true)
  showResponseTime Boolean        @default(true)
  metaTitle    String?
  metaDescription String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  team        Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  components  StatusPageComponent[]
  subscribers Subscriber[]

  @@map("status_pages")
}

model StatusPageComponent {
  id            String          @id @default(cuid())
  statusPageId  String
  monitorId     String?
  name          String
  description   String?
  groupName     String?
  displayOrder  Int             @default(0)
  status        ComponentStatus @default(OPERATIONAL)
  showUptime    Boolean         @default(true)
  createdAt     DateTime        @default(now())

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  monitor    Monitor?   @relation(fields: [monitorId], references: [id], onDelete: SetNull)

  @@map("status_page_components")
}

// ─── Alert Channels & Rules ──────────────────────────────────────────────────

model AlertChannel {
  id        String           @id @default(cuid())
  teamId    String
  type      AlertChannelType
  name      String
  config    String           @db.Text  // encrypted JSON
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  team          Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  alertRules    AlertRule[]
  notifications AlertNotification[]

  @@map("alert_channels")
}

model AlertRule {
  id        String       @id @default(cuid())
  monitorId String
  channelId String
  trigger   AlertTrigger
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())

  monitor Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  channel AlertChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([monitorId, channelId, trigger])
  @@map("alert_rules")
}

model AlertNotification {
  id        String             @id @default(cuid())
  monitorId String
  channelId String
  trigger   AlertTrigger
  status    NotificationStatus @default(PENDING)
  error     String?
  sentAt    DateTime?
  createdAt DateTime           @default(now())

  channel AlertChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("alert_notifications")
}

// ─── Maintenance Windows ─────────────────────────────────────────────────────

model MaintenanceWindow {
  id         String   @id @default(cuid())
  teamId     String
  name       String
  monitorIds String[]
  startAt    DateTime
  endAt      DateTime
  reason     String?
  createdAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("maintenance_windows")
}

// ─── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id         String   @id @default(cuid())
  teamId     String
  name       String
  keyHash    String   @unique
  keyPrefix  String
  scopes     String[] @default(["read"])
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── Subscribers ─────────────────────────────────────────────────────────────

model Subscriber {
  id           String   @id @default(cuid())
  statusPageId String
  email        String?
  phone        String?
  componentIds String[] @default([])
  token        String   @unique @default(cuid())
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  @@map("subscribers")
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Subscription {
  id                String             @id @default(cuid())
  teamId            String             @unique
  stripeSubId       String             @unique
  stripePriceId     String
  plan              Plan
  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
